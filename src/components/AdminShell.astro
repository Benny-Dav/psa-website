---
import { site } from '@/data/site';

interface Props {
  active: 'dashboard' | 'events' | 'calendar' | 'bookings' | 'gallery';
  eyebrow: string;
  title: string;
  description: string;
}

const { active, eyebrow, title, description } = Astro.props;

const navItems = [
  {
    id: 'dashboard',
    label: 'Dashboard',
    href: '/admin',
    icon: 'M4 5.5A1.5 1.5 0 0 1 5.5 4h4A1.5 1.5 0 0 1 11 5.5v4A1.5 1.5 0 0 1 9.5 11h-4A1.5 1.5 0 0 1 4 9.5v-4Zm9 0A1.5 1.5 0 0 1 14.5 4h4A1.5 1.5 0 0 1 20 5.5v4a1.5 1.5 0 0 1-1.5 1.5h-4A1.5 1.5 0 0 1 13 9.5v-4Zm-9 9A1.5 1.5 0 0 1 5.5 13h4a1.5 1.5 0 0 1 1.5 1.5v4A1.5 1.5 0 0 1 9.5 20h-4A1.5 1.5 0 0 1 4 18.5v-4Zm9 0a1.5 1.5 0 0 1 1.5-1.5h4a1.5 1.5 0 0 1 1.5 1.5v4a1.5 1.5 0 0 1-1.5 1.5h-4a1.5 1.5 0 0 1-1.5-1.5v-4Z'
  },
  {
    id: 'events',
    label: 'Events',
    href: '/admin/events',
    icon: 'M7 2v2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-2V2h-2v2H9V2H7Zm12 8H5v8h14v-8ZM5 8h14V6H5v2Z'
  },
  {
    id: 'calendar',
    label: 'Calendar',
    href: '/admin/calendar',
    icon: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm1 5v4.6l3.2 3.2-1.4 1.4L11 12.4V7h2Z'
  },
  {
    id: 'bookings',
    label: 'Bookings',
    href: '/admin/bookings',
    icon: 'M4 4h16v12H7.8L4 19.8V4Zm2 2v9l1-1h11V6H6Zm3 3h6v2H9V9Zm0 3h8v2H9v-2Z'
  },
  {
    id: 'gallery',
    label: 'Gallery',
    href: '/admin/gallery',
    icon: 'M5 4h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm0 2v8.6l3.2-3.2 3 3 4.2-4.8L19 13.7V6H5Zm3.5 4A1.5 1.5 0 1 0 8.5 7a1.5 1.5 0 0 0 0 3Z'
  }
] as const;
---

<div class="admin-shell" data-admin-shell>
  <aside class="admin-sidebar" aria-label="Admin navigation">
    <a class="admin-sidebar__brand" href="/admin" aria-label={`${site.name} admin dashboard`}>
      <img src="/images/psa-logo.png" alt="" />
      <span>{site.shortName}</span>
    </a>

    <nav class="admin-sidebar__nav">
      {
        navItems.map((item) => (
          <a class:list={[item.id === active && 'is-active']} href={item.href} aria-label={item.label} title={item.label}>
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path d={item.icon}></path>
            </svg>
            <span>{item.label}</span>
          </a>
        ))
      }
    </nav>

    <div class="admin-sidebar__bottom">
      <a href="/" aria-label="View public site" title="View site">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M12 2a10 10 0 0 0 0 20 10 10 0 0 0 0-20Zm6.9 9h-3a15.8 15.8 0 0 0-1.2-5A8.1 8.1 0 0 1 18.9 11ZM12 4.1c.7 1 1.5 3.1 1.8 6.9h-3.6c.3-3.8 1.1-5.9 1.8-6.9ZM4.3 13h3.8c.1 1.8.4 3.4.8 4.8A8 8 0 0 1 4.3 13Zm3.8-2H4.3a8 8 0 0 1 4.6-4.8A19 19 0 0 0 8.1 11ZM12 19.9c-.7-1-1.5-3.1-1.8-6.9h3.6c-.3 3.8-1.1 5.9-1.8 6.9Zm3.1-2.1c.4-1.4.7-3 .8-4.8h3.8a8 8 0 0 1-4.6 4.8Z"></path>
        </svg>
        <span>View Site</span>
      </a>
      <button type="button" data-admin-sign-out aria-label="Sign out" title="Sign out">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M10 3h9a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-9v-2h9V5h-9V3Zm1.7 5.3L13.1 7 18 12l-4.9 5-1.4-1.3 2.6-2.7H3v-2h11.3l-2.6-2.7Z"></path>
        </svg>
        <span>Sign Out</span>
      </button>
    </div>
  </aside>

  <main class="admin-main">
    <header class="admin-main__header">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <p>{description}</p>
      </div>
    </header>
    <slot />
  </main>
</div>

<script>
  import { onAuthStateChanged, signOut } from 'firebase/auth';
  import { getFirebaseAuth, isFirebaseConfigured } from '@/lib/firebase';

  const signOutButton = document.querySelector('[data-admin-sign-out]');

  if (!isFirebaseConfigured) {
    window.location.replace('/admin/login');
  } else {
    const auth = getFirebaseAuth();
    if (auth) {
      onAuthStateChanged(auth, (user) => {
        if (!user) {
          window.location.replace('/admin/login');
          return;
        }

      });

      signOutButton?.addEventListener('click', async () => {
        await signOut(auth);
        window.location.replace('/admin/login');
      });
    }
  }
</script>
