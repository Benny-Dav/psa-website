---
import AdminShell from '@/components/AdminShell.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';
---

<BaseLayout title={`Bookings Admin | ${site.name}`} description="Review booking requests.">
  <AdminShell active="bookings" eyebrow="Bookings" title="Booking Requests" description="View submitted consultation requests.">
    <section class="admin-panel">
      <div class="admin-panel__heading">
        <h2>Recent requests</h2>
        <button class="admin-icon-button" type="button" data-bookings-refresh aria-label="Refresh booking requests" title="Refresh requests">
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M17.7 6.3A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.8-4.2L13 11h8V3l-3.3 3.3Z"></path></svg>
        </button>
      </div>

      <div class="admin-list admin-list--bookings" data-bookings-list>
        <p class="admin-empty">Loading booking requests...</p>
      </div>
    </section>
  </AdminShell>
</BaseLayout>

<script>
  import { listBookingRequests, type BookingRequest } from '@/lib/adminData';
  import { isFirebaseConfigured } from '@/lib/firebase';

  const bookingsList = document.querySelector('[data-bookings-list]');
  const bookingsRefresh = document.querySelector('[data-bookings-refresh]');

  function escapeHtml(value: unknown) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function errorMessage(error: unknown, fallback: string) {
    const errorWithCode = error as { code?: string; message?: string };
    if (errorWithCode?.code) return `${fallback} (${errorWithCode.code})`;
    if (errorWithCode?.message) return `${fallback} (${errorWithCode.message})`;
    return fallback;
  }

  function formatTimestamp(value: unknown) {
    const timestamp = value as { toDate?: () => Date; seconds?: number };
    const date = timestamp?.toDate instanceof Function
      ? timestamp.toDate()
      : typeof timestamp?.seconds === 'number'
        ? new Date(timestamp.seconds * 1000)
        : null;

    if (!date || Number.isNaN(date.getTime())) return 'Date not available';

    return date.toLocaleString('en', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      hour: 'numeric',
      minute: '2-digit'
    });
  }

  function statusLabel(status?: BookingRequest['status']) {
    if (!status) return 'Request Received';

    return status
      .split('_')
      .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' ');
  }

  function renderBookings(requests: BookingRequest[]) {
    if (!(bookingsList instanceof HTMLElement)) return;

    bookingsList.innerHTML = requests.length
      ? requests.map((request) => `
        <article class="admin-booking-card">
          <span class="admin-booking-card__status">${escapeHtml(statusLabel(request.status))}</span>
          <div class="admin-booking-card__topline">
            <div>
              <strong>${escapeHtml(request.fullName || 'Unnamed visitor')}</strong>
              <p>${escapeHtml(formatTimestamp(request.createdAt))}</p>
            </div>
          </div>

          <dl class="admin-booking-card__details">
            <div>
              <dt>Preferred Date</dt>
              <dd>${escapeHtml(request.date || 'Not provided')}</dd>
            </div>
            <div>
              <dt>Preferred Time</dt>
              <dd>${escapeHtml(request.slot || 'Not provided')}</dd>
            </div>
            <div>
              <dt>WhatsApp Number</dt>
              <dd>${escapeHtml(request.whatsapp || 'Not provided')}</dd>
            </div>
            ${request.reason ? `
              <div class="admin-booking-card__reason">
                <dt>Reason</dt>
                <dd>${escapeHtml(request.reason)}</dd>
              </div>
            ` : ''}
          </dl>
        </article>
      `).join('')
      : '<p class="admin-empty">No booking requests yet.</p>';
  }

  async function refreshBookings() {
    if (!(bookingsList instanceof HTMLElement)) return;

    if (!isFirebaseConfigured) {
      bookingsList.innerHTML = '<p class="admin-empty">Firebase is not configured yet. Add .env.local values before viewing booking requests.</p>';
      return;
    }

    bookingsList.innerHTML = '<p class="admin-empty">Loading booking requests...</p>';

    try {
      renderBookings(await listBookingRequests());
    } catch (error) {
      console.error(error);
      bookingsList.innerHTML = `<p class="admin-empty">${escapeHtml(errorMessage(error, 'Unable to load booking requests. Check Firebase permissions.'))}</p>`;
    }
  }

  bookingsRefresh?.addEventListener('click', () => {
    void refreshBookings();
  });

  void refreshBookings();
</script>
