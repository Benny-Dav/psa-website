---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/data/site';
---

<BaseLayout title={`Admin Login | ${site.name}`} description="Sign in to manage the ministry website.">
  <main class="admin-page">
    <section class="admin-auth">
      <div>
        <p class="eyebrow">Admin</p>
        <h1>Website Control Room</h1>
        <p>Sign in to manage events, calendar availability, and booking requests.</p>
      </div>

      <form class="admin-form" data-login-form>
        <label>
          <span>Email</span>
          <input type="email" name="email" autocomplete="email" required />
        </label>
        <label>
          <span>Password</span>
          <div class="admin-password-field">
            <input type="password" name="password" autocomplete="current-password" required data-password-input />
            <button type="button" data-password-toggle aria-label="Show password" aria-pressed="false" title="Show password">
              <svg data-password-icon-show width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12Z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              <svg data-password-icon-hide width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" hidden>
                <path d="M2 12s3.5-7 10-7a10.6 10.6 0 0 1 5.5 1.6M22 12s-3.5 7-10 7a10.6 10.6 0 0 1-5.5-1.6"></path>
                <path d="M4 4l16 16"></path>
                <path d="M9.9 9.9A3 3 0 0 0 14.1 14.1"></path>
              </svg>
            </button>
          </div>
        </label>
        <button class="button button--primary button--full" type="submit" data-login-button>Sign In</button>
        <p class="admin-note" data-login-note></p>
      </form>
    </section>
  </main>
</BaseLayout>

<script>
  import { onAuthStateChanged, signInWithEmailAndPassword } from 'firebase/auth';
  import { getFirebaseAuth, isFirebaseConfigured } from '@/lib/firebase';

  const loginForm = document.querySelector('[data-login-form]');
  const loginNote = document.querySelector('[data-login-note]');
  const loginButton = document.querySelector('[data-login-button]');
  const passwordInput = document.querySelector('[data-password-input]');
  const passwordToggle = document.querySelector('[data-password-toggle]');
  const passwordIconShow = document.querySelector('[data-password-icon-show]');
  const passwordIconHide = document.querySelector('[data-password-icon-hide]');

  function setNote(message: string) {
    if (loginNote instanceof HTMLElement) loginNote.textContent = message;
  }

  function formData(form: HTMLFormElement) {
    return Object.fromEntries(new FormData(form).entries()) as Record<string, string>;
  }

  passwordToggle?.addEventListener('click', () => {
    if (!(passwordInput instanceof HTMLInputElement) || !(passwordToggle instanceof HTMLButtonElement)) return;
    const showPassword = passwordInput.type === 'password';
    passwordInput.type = showPassword ? 'text' : 'password';
    passwordToggle.setAttribute('aria-label', showPassword ? 'Hide password' : 'Show password');
    passwordToggle.setAttribute('aria-pressed', String(showPassword));
    passwordToggle.setAttribute('title', showPassword ? 'Hide password' : 'Show password');
    if (passwordIconShow instanceof SVGElement) passwordIconShow.hidden = showPassword;
    if (passwordIconHide instanceof SVGElement) passwordIconHide.hidden = !showPassword;
  });

  if (!isFirebaseConfigured) {
    setNote('Firebase is not configured yet. Add your project values to .env.local.');
  } else {
    const auth = getFirebaseAuth();

    if (auth) {
      onAuthStateChanged(auth, (user) => {
        if (user) window.location.replace('/admin');
      });

      loginForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!(loginForm instanceof HTMLFormElement) || !(loginButton instanceof HTMLButtonElement)) return;
        const data = formData(loginForm);
        loginButton.disabled = true;
        loginButton.textContent = 'Signing In...';
        setNote('');

        try {
          await signInWithEmailAndPassword(auth, data.email, data.password);
          window.location.replace('/admin');
        } catch {
          setNote('Unable to sign in. Check the email and password.');
        } finally {
          loginButton.disabled = false;
          loginButton.textContent = 'Sign In';
        }
      });
    }
  }
</script>
