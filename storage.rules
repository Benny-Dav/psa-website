rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isGalleryImage() {
      return request.resource.contentType.matches('image/(jpeg|png|webp)')
        && request.resource.size < 10 * 1024 * 1024;
    }

    function isEventFlyer() {
      return (request.resource.contentType.matches('image/(jpeg|png|webp)')
        || request.resource.contentType == 'application/pdf')
        && request.resource.size < 10 * 1024 * 1024;
    }

    match /gallery/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn() && isGalleryImage();
      allow delete: if isSignedIn();
    }

    match /event-flyers/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn() && isEventFlyer();
      allow delete: if isSignedIn();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
